# dependencies (bun install)
node_modules

# output
out
dist
*.tgz

# code coverage
coverage
*.lcov

# logs
logs
_.log
report.[0-9]_.[0-9]_.[0-9]_.[0-9]_.json

# dotenv environment variable files
.env
.env.development.local
.env.test.local
.env.production.local
.env.local

# caches
.eslintcache
.cache
*.tsbuildinfo

# IntelliJ based IDEs
.idea

# Finder (MacOS) folder config
.DS_Store

# Claude Code
.claude/*
!.claude/CLAUDE.md
!.claude/bug-hunt.md
CLAUDE.local.md

# Devcontainer env file — may hold a host gh token (GH_TOKEN); never commit it
.devcontainer/.env

# Marp slide deck PDFs (regenerated from doc/walkthrough/slides/*.md)
doc/walkthrough/slides/pdf/
doc/walkthrough/slides/*.pdf

# Course handout PDFs (regenerated via `bun run handout:pdf`)
doc/courses/**/*.pdf

# HTML-rendered spec (regenerated via `bun run spec:html` / playground build)
packages/playground/public/spec.html

# HTML-rendered embed tutorial (regenerated via `bun run tutorial:html` / playground build)
packages/playground/tutorial.html

# Playwright
playwright-report/
test-results/
.playwright/

# Core dumps (top-level only — `core` unanchored would shadow the
# `packages/core` workspace and silently ignore new files added there)
/core

# Python (datamog-magic)
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
build/

# Jupyter
.ipynb_checkpoints/
