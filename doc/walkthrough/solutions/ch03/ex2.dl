# Exercise 3.2 solution.
#
# Two rules that overlap on most people in the dataset. Datalog
# set semantics removes the duplicates automatically.

extensional parent(parent_name: string, child_name: string).
extensional marriage(p1: string, p2: string).

involved_in_family(P) :- parent(P, _).
involved_in_family(P) :- marriage(P, _).
involved_in_family(P) :- marriage(_, P).

?- involved_in_family(P).
