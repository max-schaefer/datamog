# Exercise 4.2 solution.
#
# Reflexivity needs two rules — one for nodes that appear as
# sources, one for nodes that appear as destinations. Using just
# one would miss nodes that appear in only one column.

extensional edge(src: string, dst: string).

reach_or_self(X, Y) :- edge(X, Y).
reach_or_self(X, Y) :- edge(X, Z), reach_or_self(Z, Y).

reach_or_self(X, X) :- edge(X, _).
reach_or_self(X, X) :- edge(_, X).

?- reach_or_self("a", Y).
?- reach_or_self(X, X).
