# Exercise 4.1 solution.
#
# Three separate rules, one per value of K. Non-recursive — each
# rule references `edge` directly the right number of times.

input predicate edge(src: string, dst: string).

reach_in("1", X, Y) :- edge(X, Y).
reach_in("2", X, Y) :- edge(X, Z), edge(Z, Y).
reach_in("3", X, Y) :- edge(X, A), edge(A, B), edge(B, Y).

output predicate reach2(Y) :- reach_in("2", "a", Y).
output predicate reach3(Y) :- reach_in("3", "a", Y).

?- reach_in("1", "a", Y).
