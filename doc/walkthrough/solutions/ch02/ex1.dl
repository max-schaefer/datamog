# Exercise 2.1 solution.
#
# "X is a grandchild of Y" is the mirror image of
# "Y is a grandparent of X" ‚Äî swap the argument order and trace
# through child‚Üíparent‚Üíparent.

input predicate parent(parent_name: string, child_name: string).

grandchild(X, Y) :- parent(Z, X), parent(Y, Z).

?- grandchild(X, Y).
