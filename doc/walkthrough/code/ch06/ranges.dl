# Tutorial, chapter 6 — range atoms.
#
# A range atom `X in [lo .. hi]` binds X to each integer in the
# inclusive range [lo, hi]. It's how Datalog generates values.

# All integers from 1 to 10.
num(N) :- N in [1 .. 10].

# Perfect squares up to 100.
output predicate square(N, S) :- N in [1 .. 10], S = N * N.

# Multiplication table for 3.
output predicate times_three(N, T) :- N in [1 .. 5], T = N * 3.

?- num(N).
