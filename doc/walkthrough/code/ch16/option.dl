# option.dl -- the Option type, parameterised over its element predicate.
#
# `elem` is the type parameter: an importer wires it to any unary relation,
# and this file becomes Option of that element type. `elem` is a `value`
# column, so the element type can be anything (integers, strings, ...).
input predicate elem(v: value).

# Two constructors: None, or Some(v) for each element v.
output predicate opt() :: None.
output predicate opt() :: Some :- elem(V).
