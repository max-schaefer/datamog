# Exercise 9.1 — Simple counts.

extensional scores(student: string, subject: string, score: integer).

# TODO: three aggregate rules.

# Placeholders so the file parses.
subject_count(Subject, count(*)) :- scores(_, Subject, _).
output predicate total_students(count(Student)) :- scores(Student, _, _).
output predicate perfect_scores(count(*)) :- scores(_, _, S), S = 999.

?- subject_count(Subject, N).
