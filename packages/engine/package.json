{
  "name": "datamog-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Execution engine, SQL translator, loaders, and result utilities for Datamog",
  "license": "MIT",
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "files": ["src"],
  "exports": {
    ".": "./src/index.ts",
    "./directory-loader": "./src/directory-loader.ts",
    "./module-resolver": "./src/module-resolver.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/max-schaefer/datamog",
    "directory": "packages/engine"
  },
  "keywords": ["datalog", "sql", "translator", "executor", "loader", "bun", "datamog"],
  "author": "Max Schaefer",
  "homepage": "https://github.com/max-schaefer/datamog/tree/main/packages/engine#readme",
  "bugs": {
    "url": "https://github.com/max-schaefer/datamog/issues"
  },
  "dependencies": {
    "datamog-core": "workspace:*",
    "datamog-parser": "workspace:*"
  },
  "devDependencies": {
    "datamog-backend-postgres": "workspace:*",
    "datamog-backend-sqlite": "workspace:*"
  }
}
