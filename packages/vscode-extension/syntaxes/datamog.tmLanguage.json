{
  "name": "Datamog",
  "scopeName": "source.datamog",
  "patterns": [
    { "include": "#comment" },
    { "include": "#query" },
    { "include": "#declaration" },
    { "include": "#string" },
    { "include": "#number" },
    { "include": "#keyword" },
    { "include": "#aggregate" },
    { "include": "#type" },
    { "include": "#variable" },
    { "include": "#predicate" },
    { "include": "#operator" }
  ],
  "repository": {
    "comment": {
      "match": "#.*$",
      "name": "comment.line.number-sign.datamog"
    },
    "query": {
      "match": "\\?-",
      "name": "keyword.control.query.datamog"
    },
    "declaration": {
      "match": "\\b(input|output|predicate)\\b",
      "name": "keyword.declaration.datamog"
    },
    "string": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.datamog",
      "patterns": [
        {
          "match": "\\\\.",
          "name": "constant.character.escape.datamog"
        }
      ]
    },
    "number": {
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b",
      "name": "constant.numeric.datamog"
    },
    "keyword": {
      "match": "\\b(not|in|true|false|null)\\b",
      "name": "keyword.operator.datamog"
    },
    "aggregate": {
      "match": "\\b(count|sum|avg|min|max|concat|list)\\b(?=\\s*\\()",
      "name": "support.function.aggregate.datamog"
    },
    "type": {
      "match": "\\b(string|integer|float|boolean|value)\\b",
      "name": "support.type.datamog"
    },
    "variable": {
      "match": "\\b[A-Z_][a-zA-Z0-9_]*\\b",
      "name": "variable.other.datamog"
    },
    "predicate": {
      "match": "\\b[a-z][a-zA-Z0-9_]*\\b(?=\\s*\\()",
      "name": "entity.name.function.predicate.datamog"
    },
    "operator": {
      "match": ":-|\\.\\.|\\.(?!\\.)|>>>|>>|<<|<=|>=|==|!=|<>|&&|\\|\\||[!<>=+\\-*/%,{}&|^]",
      "name": "keyword.operator.datamog"
    }
  }
}
