# Stratified negation example
# Find the "frontier" of a directed graph: nodes reachable from "a"
# that have no outgoing edges.

input predicate edge(src: string, dst: string).

reachable(X) :- edge("a", X).
reachable(X) :- edge(Y, X), reachable(Y).

has_outgoing(X) :- edge(X, _).

frontier(X) :- reachable(X), not has_outgoing(X).

?- frontier(X).
