# JSON events — destructure web request log records.
#
# Each line of event.jsonl is a self-describing event with arbitrary
# nested shape. The single-json-column extensional consumes the line
# as-is; rules pull fields out via JSON subscript, iterate over nested
# arrays / objects with object_entry and array_element, and coerce
# leaves to primitive SQL types via as_string / as_integer / as_float /
# as_boolean / length / type_of.

extensional event(payload: value).

# Coerce top-level fields to primitive SQL types so we can compare
# them with string/integer literals downstream.
request(Id, Method, Path, Status) :-
    event(E),
    Id = as_integer(E["id"]),
    Method = as_string(E["method"]),
    Path = as_string(E["path"]),
    Status = as_integer(E["status"]).

# String-comparison + range filter on coerced values: Phase A could
# project these but couldn't compare them to literals.
output predicate ok_v1_request(Id, Path) :-
    request(Id, _, Path, Status),
    Status >= 200,
    Status < 300,
    Path[0:4] = "/v1/".

# Iterate the headers object and project (event-id, key, value-as-string)
# for header values that are JSON strings.
output predicate event_string_header(Id, Key, Value) :-
    event(E),
    Id = as_integer(E["id"]),
    object_entry(E["headers"], Key, V),
    Value = as_string(V).

# Tag count per event: array length on each tags array. Events with
# no `tags` field yield NULL, which `as_integer` then keeps as NULL — but
# the IDB is integer-typed so we want a real integer. Use the json
# length builtin and coerce; events without tags simply don't appear.
output predicate tag_count(Id, N) :-
    event(E),
    Id = as_integer(E["id"]),
    N = length(E["tags"]).

# Type breakdown: list each top-level field's name and its `value`-leaf
# type. Uses every Phase A/B/C primitive in one rule.
output predicate field_types(Id, Field, Type) :-
    event(E),
    Id = as_integer(E["id"]),
    object_entry(E, Field, V),
    Type = type_of(V).

?- request(Id, M, P, S).
