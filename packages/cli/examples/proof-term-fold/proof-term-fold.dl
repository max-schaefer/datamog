# Folding proof terms with constructor patterns
#
# A constructor pattern matches a proof term against a constructor. In a rule
# head it reads as an implicit equality against that column, so `list_sum` folds
# over the list proof terms of `num_list` to sum their elements: one rule per
# constructor, with the head expression combining the tail's sum with the
# matched head.

num(1). num(2).

num_list(0)[Nil].
num_list(n + 1)[Cons] :- num(Car), n <= 1, num_list(n).

# A catamorphism: Nil sums to 0; Cons adds its (coerced) head to the tail's sum.
list_sum(Nil(), 0).
list_sum(Cons(H, T), S + as_integer(H)) :- list_sum(T, S).

# Pair each list (shown by its proof term) with its sum.
?- Xs : num_list, list_sum(Xs, S).
