{
  "name": "datamog",
  "license": "MIT",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*", "packages/backend/*", "packages/loader/*"],
  "scripts": {
    "test": "bun test --recursive",
    "typecheck": "tsc -b",
    "check": "bunx biome check .",
    "check:fix": "bunx biome check --fix .",
    "datamog": "bun packages/cli/src/main.ts",
    "build:vscode": "node packages/vscode-extension/esbuild.mjs && cd packages/vscode-extension && npx @vscode/vsce package -o datamog.vsix --no-dependencies",
    "playground:dev": "bun --filter datamog-playground dev",
    "playground:build": "bun --filter datamog-playground build"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1",
    "@types/bun": "latest",
    "@vscode/vsce": "^3.7.1",
    "langium-cli": "^4.2.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
