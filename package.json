{
  "name": "datamog",
  "description": "Educational Datalog dialect with SQL backends, in-memory evaluators, CLI, playground, and editor tooling",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/max-schaefer/datamog"
  },
  "keywords": [
    "datalog",
    "logic-programming",
    "sql",
    "sqlite",
    "postgres",
    "bun",
    "playground",
    "typescript",
    "datamog"
  ],
  "author": "Max Schaefer",
  "homepage": "https://github.com/max-schaefer/datamog#readme",
  "bugs": {
    "url": "https://github.com/max-schaefer/datamog/issues"
  },
  "type": "module",
  "workspaces": ["packages/*", "packages/backend/*", "packages/loader/*"],
  "scripts": {
    "test": "bun test --recursive",
    "test:coverage": "bun test --recursive --coverage",
    "typecheck": "tsc -b",
    "check": "bunx biome check .",
    "check:fix": "bunx biome check --fix .",
    "datamog": "bun packages/cli/src/main.ts",
    "build:cli": "bun build --compile packages/cli/src/main.ts --outfile dist/datamog",
    "build:vscode": "node packages/vscode-extension/esbuild.mjs && cd packages/vscode-extension && npx @vscode/vsce package -o datamog.vsix --no-dependencies",
    "spec:html": "node scripts/build-spec-html.mjs",
    "tutorial:html": "node scripts/build-tutorial-html.mjs",
    "docs:html": "node scripts/build-spec-html.mjs && node scripts/build-tutorial-html.mjs",
    "playground:dev": "bun run docs:html && node scripts/ensure-rollup-native.mjs && bun --filter datamog-playground dev",
    "playground:build": "bun run docs:html && node scripts/ensure-rollup-native.mjs && bun --filter datamog-playground build",
    "e2e": "playwright install chromium && playwright test",
    "e2e:ui": "playwright install chromium && playwright test --ui",
    "slides:build": "bunx @marp-team/marp-cli@latest --pdf --allow-local-files --input-dir doc/walkthrough/slides --output-dir doc/walkthrough/slides/pdf",
    "slides:watch": "bunx @marp-team/marp-cli@latest --watch --pdf --allow-local-files --input-dir doc/walkthrough/slides --output-dir doc/walkthrough/slides/pdf",
    "handout:pdf": "playwright install chromium && bun run doc/courses/flolac-26/build-pdf.ts"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1",
    "@playwright/test": "^1.59.1",
    "@types/bun": "latest",
    "@vscode/vsce": "^3.7.1",
    "langium-cli": "^4.2.0",
    "marked": "^18.0.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
